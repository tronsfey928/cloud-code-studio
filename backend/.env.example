# Server
PORT=5000
NODE_ENV=development

# Database (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=cloudcode
MYSQL_PASSWORD=cloudcode
MYSQL_DATABASE=cloudcode

# Redis (optional — leave empty to use in-memory cache)
REDIS_URL=

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRY=24h

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=info

# File Uploads
MAX_FILE_SIZE=10485760

# Workspace storage directory
WORKSPACES_DIR=/data/workspaces

# OpenCode LLM Configuration
OPENCODE_LLM_PROVIDER=anthropic
OPENCODE_LLM_MODEL=
OPENCODE_LLM_API_KEY=
OPENCODE_LLM_BASE_URL=
